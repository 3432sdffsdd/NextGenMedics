APP_ENV=development
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=nextgen_medics
DB_USER=root
DB_PASS=
JWT_SECRET=change-this-to-a-long-random-secret-key-in-production
JWT_REFRESH_SECRET=change-this-to-another-long-random-secret-key
MAIL_FROM=noreply@nextgenmedics.com
MAIL_FROM_NAME=NextGen Medics
CRON_SECRET=ngm-cron-local-dev

# WhatsApp Cloud API — run backend\setup-whatsapp.bat for guided setup
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# AI Learning Assistant (FCPS content generation)
# Works with any OpenAI-compatible Chat Completions API.
# Examples:
#   OpenAI:      AI_BASE_URL=https://api.openai.com/v1        AI_MODEL=gpt-4o-mini
#   OpenRouter:  AI_BASE_URL=https://openrouter.ai/api/v1     AI_MODEL=openai/gpt-4o-mini
#   Groq (FREE): AI_PROVIDER=groq  AI_BASE_URL=https://api.groq.com/openai/v1  AI_MODEL=llama-3.3-70b-versatile
#   Run: backend\setup-ai.bat
#   Local:       AI_BASE_URL=http://127.0.0.1:11434/v1        AI_MODEL=llama3.1
AI_ENABLED=true
AI_PROVIDER=openai
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.4
AI_MAX_TOKENS=4000
AI_TIMEOUT=120

# ── AI Generation Engine (Google Gemini) ──────────────────────────
# Native Gemini engine for the staged FCPS content generator.
# Get a key at https://aistudio.google.com/apikey — NEVER commit it.
# Default model is Gemini 3.5 Flash (2.5 Flash is closed to new keys).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TEMPERATURE=0.4
GEMINI_TOP_P=0.95
GEMINI_TOP_K=40
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_TIMEOUT=120
GEMINI_MAX_RETRIES=3
GEMINI_MAX_INPUT_CHARS=100000

# ── AI Study Planner (Groq) ───────────────────────────────────
# Premium FCPS Part 1 planner. Get a key at https://console.groq.com/keys
# Never commit real keys. Model default: openai/gpt-oss-20b
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-20b
GROQ_TEMPERATURE=0.5
GROQ_MAX_TOKENS=4096
GROQ_TIMEOUT=120
GROQ_MAX_RETRIES=3
